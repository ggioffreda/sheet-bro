{
  "name": "sheet-bro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/stamp-sw.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "pnpm typecheck && pnpm test:coverage && pnpm test:e2e"
  },
  "dependencies": {
    "@univerjs/preset-sheets-core": "0.20.0",
    "@univerjs/preset-sheets-filter": "0.20.0",
    "@univerjs/presets": "0.20.0",
    "@zip.js/zip.js": "2.8.26",
    "papaparse": "5.5.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "read-excel-file": "8.0.3",
    "rxjs": "7.8.2",
    "sql.js": "1.14.1",
    "write-excel-file": "3.0.8"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/papaparse": "5.5.2",
    "@types/sql.js": "1.4.11",
    "@vitest/coverage-v8": "4.1.4",
    "fake-indexeddb": "6.2.5",
    "happy-dom": "20.8.9",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "4.1.4"
  }
}
